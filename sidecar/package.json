{
  "name": "droid-control-sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Node sidecar bridging the Tauri frontend to the Factory droid daemon via @factory/droid-sdk",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/sidecar.mjs",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@factory/droid-sdk": "^0.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
