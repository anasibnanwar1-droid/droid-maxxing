# Local development defaults. Copy to .env and override only what you need.

# Electron development shell target. Vite defaults to port 1420 for this app.
ELECTRON_START_URL=http://127.0.0.1:1420

# Sidecar WebSocket bridge settings.
BRIDGE_PORT=8765
BRIDGE_TOKEN=
BRIDGE_ALLOW_LOCAL_NO_TOKEN=1
BRIDGE_EXIT_ON_STDIN_CLOSE=1

# Optional Droid CLI override. Leave blank to use PATH discovery.
DROID_PATH=

# Optional Factory API key for local Droid child processes.
# Never commit a real key.
FACTORY_API_KEY=

# Optional update and download overrides used by packaged Electron builds.
DROID_DOWNLOAD_BASE=https://droidex.app
DROID_UPDATE_FEED=
DROID_UPDATE_HOSTS=

# Optional development overrides.
SIDECAR_ENTRY=
NODE_BIN=
DROID_NATIVE_BROWSER_IDLE_MS=300000
DROID_CONTROL_MAX_OPEN_AGENTS=4
DROID_CONTROL_BROWSER_NATIVE_TIMEOUT_MS=12000

# Platform variables used for CLI discovery. Normally inherit these from your shell.
# PATH=/usr/local/bin:/usr/bin:/bin
# PATHEXT=.COM;.EXE;.BAT;.CMD
# ComSpec=C:\Windows\System32\cmd.exe
