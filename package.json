{
  "name": "droid-control",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run sidecar:build && npm run electron:check",
    "electron": "npm run electron:dev",
    "electron:dev": "npm run sidecar:build && node electron/dev.cjs",
    "electron:check": "node --check electron/main.cjs && node --check electron/preload.cjs && node --check electron/nativeBrowserPreload.cjs && node --check electron/dev.cjs",
    "sidecar:build": "npm --prefix sidecar run build",
    "sidecar:test": "npm --prefix sidecar run test",
    "sidecar:typecheck": "npm --prefix sidecar run typecheck",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "sidecar:typecheck:strict": "npm --prefix sidecar run typecheck:strict",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^39.2.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.4.47",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0"
  }
}
